{
  "kernel": {
    "mode": true
  },
  "egress_proxy": {
    "enabled": true,
    "socket_dir": "/run/studio",
    "connect_timeout_seconds": 10,
    "read_timeout_seconds": 30
  },
  "worker": {
    "global_concurrency": 4,
    "default_timeout_hours": {
      "small": 2,
      "medium": 4,
      "large": 8
    },
    "heartbeat_max_interval_minutes": 60,
    "heartbeat_timeout_multiplier": 2.0
  },
  "ollama_cloud": {
    "base_url": "https://ollama.com/api",
    "health_check_interval_seconds": 30,
    "grace_window_minutes": 5
  },
  "orchestrator": {
    "socket_path": "/run/studio/orchestrator.sock",
    "db_path": "/var/lib/studio/state.db",
    "socket_permissions": "0660",
    "socket_owner": "studio:studio",
    "memory_root": "memory/",
    "http_port": 7810
  },
  "artifacts": {
    "inline_threshold_bytes": 4096,
    "global_storage_cap_bytes": 50000000000,
    "per_bundle_cap_bytes": 1000000000,
    "per_artifact_limit_bytes": 100000000,
    "task_retention_seconds": 86400,
    "bundle_retention_complete_seconds": 604800,
    "bundle_retention_failed_seconds": 2592000
  },
  "mcp": {
    "port": 8080,
    "bearer_token": ""
  },
  "github": {
    "enabled": false,
    "app_id": "",
    "installation_id": "",
    "private_key_path": "",
    "webhook_secret": "",
    "poll_interval_seconds": 60,
    "owner": "",
    "repo": ""
  },
  "approval": {
    "low_complexity_max": 3,
    "med_complexity_max": 6,
    "low_risk_max": 2,
    "med_risk_max": 5,
    "summary_tier_default_action": "hold",
    "default_action_overrides": {},
    "summary_timeout_hours": 4,
    "cooldown_hours_reversible": 1,
    "cooldown_hours_irreversible": 24,
    "mandatory_review_triggers": [
      {
        "name": "agents_md",
        "description": "Any modification to AGENTS.md files",
        "path_patterns": ["**/AGENTS.md"]
      },
      {
        "name": "capability_manifest",
        "description": "Modification to capability manifest itself",
        "path_patterns": ["**/capability*.json", "**/capability*.yaml"]
      },
      {
        "name": "control_plane",
        "description": "Control-plane code or settings.json",
        "path_patterns": ["studio/orchestrator/**", "settings.json"]
      },
      {
        "name": "ci_config",
        "description": "GitHub Actions workflows or CI config",
        "path_patterns": [".github/workflows/**", "**/.github/workflows/**"]
      },
      {
        "name": "new_repo",
        "description": "Creating a new product repo is irreversible",
        "target_new_repo": true
      }
    ]
  },
  "ops": {
    "stall_threshold_hours": 8,
    "escalation_days": [5, 10, 21],
    "recall_window_hours": 48,
    "acting_soon_hours": 12,
    "worker_token_expiry_minutes": 15
  },
  "secrets_config": [{"name": "ollama_api_key", "env_var": "OLLAMA_API_KEY", "purpose": "llm_api"}]
}
